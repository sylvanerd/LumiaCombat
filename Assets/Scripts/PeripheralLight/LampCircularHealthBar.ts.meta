  InputLines:
    - '// @input AssignableType lampHealthManager {"hint":"The LampHealthManager driving this health bar"}'
    - '// @input AssignableType_1 lightHandEventListener {"hint":"LightHandEventListener on the lamp prefab, used to read the placement position when the game starts"}'
    - '// @input Asset.ObjectPrefab healthUIPrefab {"hint":"Prefab containing the battery-bar health UI. Instantiated at the anchor position when the game starts."}'
    - '// @input float yOffset = 30 {"hint":"Y offset above the anchor position to spawn the health UI"}'
    - '// @input string batteryBarChildName = "BatteryBar" {"hint":"Name of the RenderMeshVisual child inside the prefab that carries the battery bar mesh and material"}'
    - '// @input string fillBlendShapeName = "pCube2" {"hint":"Blend shape name on the battery-bar mesh that controls the fill level (0=empty, 1=full)"}'
    - '// @input string accentBlendShapeName = "pCube3" {"hint":"Optional secondary blend shape on the battery-bar mesh, held at a constant accent value"}'
    - '// @input float accentValue = 0.1 {"hint":"Constant weight to write into the accent blend shape (leave at 0 to disable)"}'
    - '// @input string colorPropertyName = "baseColor" {"hint":"Name of the color (vec4) property on the battery-bar material to tint based on health"}'
    - '// @input vec4 healthyColor = {0.2,1,0.4,1} {"hint":"Color at 100% health", "widget":"color"}'
    - '// @input vec4 warningColor = {1,0.85,0.2,1} {"hint":"Color at the warning threshold", "widget":"color"}'
    - '// @input vec4 dangerColor = {1,0.25,0.25,1} {"hint":"Color at 0% health", "widget":"color"}'
    - '// @input float warningThresholdPct = 50 {"hint":"Health % at which the bar reaches warningColor; below this it lerps toward dangerColor"}'
    - "// @input bool anchorEdge = true {\"hint\":\"If true, slide the battery bar's local position as it shrinks so the chosen edge stays anchored. Disable for a symmetric shrink around the center.\"}"
    - '// @input vec3 emptyShiftOffset = {-2,0,0} {"hint":"Local-space offset applied to the battery bar when it is fully empty (health=0). Linearly interpolated based on health: empty offset blends to zero at full health. For a horizontal bar of local width 4 anchored to its left edge, use (-2, 0, 0).", "showIf":"anchorEdge", "showIfValue":true}'
