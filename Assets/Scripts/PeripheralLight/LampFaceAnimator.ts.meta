  InputLines:
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"Render target"}'
    - '// @input Component.RenderMeshVisual faceMeshVisual {"hint":"RenderMeshVisual on the face quad. Material is cloned on Awake and baseTex is swapped per frame change."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"Frame textures"}'
    - '// @input Asset.Texture blinkClosedFrame {"hint":"Shared closed-eyes blink frame used by every blinking state (Tutorial / Normal / Warning / Critical)"}'
    - '// @input Asset.Texture tutorialOpenFrame {"hint":"Tutorial open frame (eyes fully open, looking up). If unset, falls back to normalOpenFrame."}'
    - '// @input Asset.Texture normalOpenFrame {"hint":"Normal open frame -- the default mid-game blink while HP is above the warning threshold"}'
    - '// @input Asset.Texture attackFrame {"hint":"Attack frame (one eye squinted, mouth open). Held for attackHoldDuration when a ball spawns."}'
    - '// @input Asset.Texture damageFrame {"hint":"Damage frame (eyes wide, mouth O). Held for damageHoldDuration when the lamp takes a hit."}'
    - '// @input Asset.Texture warningOpenFrame {"hint":"Warning open frame (droopy eyes, frown). Shown while HP is between the critical and warning thresholds."}'
    - '// @input Asset.Texture criticalOpenFrame {"hint":"Critical open frame (more droopy, mouth open). Shown while HP is below the critical threshold."}'
    - '// @input Asset.Texture deadFrame {"hint":"Dead frame (X eyes, flat mouth). Held indefinitely when the lamp dies (player wins)."}'
    - '// @input Asset.Texture victoriousFrame {"hint":"Victorious frame (smug squint, full smile). Held indefinitely when the player dies (lamp wins)."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"Timing (seconds)"}'
    - '// @input float blinkOpenDuration = 2.5 {"hint":"How long the open-eye frame holds before each blink"}'
    - '// @input float blinkClosedDuration = 0.15 {"hint":"How long the closed-eye frame holds during each blink"}'
    - '// @input float attackHoldDuration = 1 {"hint":"How long the attack frame holds before returning to the blink loop"}'
    - '// @input float damageHoldDuration = 1 {"hint":"How long the damage frame holds before returning to the blink loop"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"HP thresholds (% of max)"}'
    - '// @input float warningThresholdPct = 50 {"hint":"Below this HP the face switches to the Warning expression (default mirrors LampCircularHealthBar.warningThresholdPct)"}'
    - '// @input float criticalThresholdPct = 25 {"hint":"Below this HP the face switches to the Critical expression (default mirrors LampHealthManager.lowHealthThreshold)"}'
